# Optional: full API base URL (no trailing slash). Staging/Prod: https://api.nexa.ma/api/v1
# For local `npm run dev`, leave this unset so requests use /api/v1 and Vite proxies to http://127.0.0.1:3000 (avoids CORS).
# VITE_API_BASE_URL=http://localhost:3000/api/v1

# If the API is not on port 3000, point the dev proxy at it (used only when VITE_API_BASE_URL is unset):
# VITE_DEV_API_PROXY=http://127.0.0.1:3001

# Admin hints for local testing only (login is validated by the backend; set ADMIN_EMAILS / ADMIN_PASSWORD there).
VITE_ADMIN_EMAIL=admin@nexa.ma
VITE_ADMIN_PASSWORD=admin123
